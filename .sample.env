# GitHub API token with repo:scope
GITHUB_TOKEN=ghp_your_github_token_here

# OpenAI key for your AI prompts
OPENAI_API_KEY=sk-your_openai_key_here

# So your code can import beluga from src/
PYTHONPATH=./src

# Jira API integration
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
OPENAI_ASSISTANT_ID=

# Any other secrets/configs:
# MODEL_NAME=gpt-4
# OTHER_SETTING=foo
