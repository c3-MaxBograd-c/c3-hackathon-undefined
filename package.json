{
  "name": "c3standards",
  "description": "Standard C3 AI applications repository",
  "author": "C3 AI",
  "devDependencies": {
    "@babel/eslint-parser": "^7.24.6",
    "@babel/preset-env": "^7.24.6",
    "@babel/preset-react": "^7.24.6",
    "@babel/preset-typescript": "^7.24.6",
    "@c3-e/eslint-plugin": "^2.4.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jasmine": "^4.1.3",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^2.1.0",
    "lint-staged": "^12.5.0",
    "prettier": "3.4.2",
    "run-script-os": "^1.1.6",
    "stylelint": "^16.14.1",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "^3.8.3"
  },
  "engineStrict": true,
  "engines": {
    "npm": ">=10.0",
    "node": ">=20.10"
  },
  "scripts": {
    "preinstall": "npm prune",
    "postinstall": "run-script-os && vale sync",
    "postinstall:macos": "brew install pre-commit && pre-commit install",
    "postinstall:linux": "if grep -qE '(Microsoft|WSL)' /proc/version; then echo 'Skipping pre-commit installation on WSL'; else pip3 install pre-commit && pre-commit install; fi",
    "postinstall:win32": "echo 'Skipping pre-commit installation on Windows'",
    "prettier": "prettier --write",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "lint:file": "eslint",
    "lint:file:fix": "npm run lint:file -- --fix",
    "lint:staged": "lint-staged",
    "stylelint": "stylelint --fix",
    "danger": "danger ci"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,scss,less}": [
      "prettier --write",
      "stylelint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
